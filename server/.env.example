# Environment Variables Template
# Copy this file to .env and fill in the values

# Server Configuration
NODE_ENV=development
PORT=4000
API_URL=http://localhost:4000

# Database
DATABASE_URL="postgresql://postgres:postgres@db:5432/services_marketplace?schema=public"

# JWT Configuration
JWT_SECRET=Prueba123*
JWT_EXPIRATION=24h
JWT_COOKIE_EXPIRATION=1

# File Upload (S3 or compatible storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=services-marketplace-portfolio

# Admin Default Credentials (for seeding)
ADMIN_EMAIL=admin@marketplace.com
ADMIN_PASSWORD=Prueba123*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000

# Message Throttling
MESSAGE_THROTTLE_MAX=50
MESSAGE_THROTTLE_WINDOW_MS=3600000

# File Upload Limits
MAX_FILE_SIZE=5242880
MAX_PORTFOLIO_IMAGES=10

# CORS
CORS_ORIGIN=http://localhost:3000
