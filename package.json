{
  "name": "services-marketplace",
  "version": "0.1.0",
  "description": "A bilingual web platform connecting service providers (plumbers, electricians, locksmiths) with customers",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:server": "npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build": "npm run build:server && npm run build:client",
    "test:server": "npm run test --workspace=server",
    "test:client": "npm run test --workspace=client",
    "test": "npm run test:server && npm run test:client",
    "lint:server": "npm run lint --workspace=server",
    "lint:client": "npm run lint --workspace=client",
    "lint": "npm run lint:server && npm run lint:client",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.8.2"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "multer": "^2.1.1",
    "i18next-http-middleware": "^3.9.6",
    "i18next-fs-backend": "^2.6.5",
    "uuid": "^14.0.0",
    "glob": "^13.0.6",
    "inflight": "npm:once@^1.4.0",
    "lodash.isequal": "^4.5.0",
    "lodash.get": "^4.4.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
